generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        String       @default("student")  // "student" | "admin" | "teacher" | "parent"
  studentCode String?      @unique              // HS9-0001 format, for students only
  createdAt   DateTime     @default(now())
  submissions  Submission[]
  examAttempts ExamAttempt[]
  parentsOf    ParentStudent[] @relation("StudentRelations")
  childrenOf   ParentStudent[] @relation("ParentRelations")
}

model ParentStudent {
  id        String @id @default(cuid())
  parentId  String
  studentId String
  parent    User   @relation("ParentRelations",  fields: [parentId],  references: [id], onDelete: Cascade)
  student   User   @relation("StudentRelations", fields: [studentId], references: [id], onDelete: Cascade)
  @@unique([parentId, studentId])
}

model DbExercise {
  id          String   @id @default(cuid())
  title       String
  content     String
  topicId     String
  topicName   String
  difficulty  String   @default("medium")
  method      String?
  solution    String?
  hints       String   @default("[]")
  status      String   @default("published")   // "published" | "draft" | "review"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Exam {
  id        String        @id @default(cuid())
  title     String
  type      String        // 'hk1' | 'hk2' | 'tuyen-sinh'
  content   String        // JSON: ExamContent
  duration  Int           @default(90)
  status    String        @default("published")
  createdAt DateTime      @default(now())
  attempts  ExamAttempt[]
}

model ExamAttempt {
  id          String   @id @default(cuid())
  examId      String
  userId      String?
  userName    String?
  answers     String   // JSON: { "1a": "lời giải hs", "1b": "..." }
  score       Float?
  feedback    String?  // JSON: per-part grading detail
  submittedAt DateTime @default(now())
  exam        Exam     @relation(fields: [examId], references: [id])
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Assignment {
  id            String   @id @default(cuid())
  exerciseId    String
  exerciseTitle String
  topicId       String
  topicName     String   @default("")
  assignedTo    String   @default("all")  // "all" | JSON array of userId strings
  dueDate       DateTime?
  note          String?
  createdAt     DateTime @default(now())
  completions   AssignmentCompletion[]
}

model AssignmentCompletion {
  id           String     @id @default(cuid())
  assignmentId String
  userId       String
  completedAt  DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
}

model Submission {
  id            String   @id @default(cuid())
  userId        String?
  userName      String?
  exerciseId    String
  exerciseTitle String?
  topicId       String?
  topicName     String?
  studentAnswer String
  isCorrect     Boolean?
  score         Float?
  feedback      String?
  aiHelpCount   Int      @default(0)
  submittedAt   DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}
