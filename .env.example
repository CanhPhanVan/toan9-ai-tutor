# Neon PostgreSQL — lấy tại https://neon.tech (miễn phí)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# NextAuth secret — chạy: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# Mã bí mật để tạo tài khoản phụ huynh/admin
ADMIN_CODE="your-admin-code-here"

# Groq AI — lấy tại https://console.groq.com (miễn phí)
GROQ_API_KEY="gsk_..."

# Google Gemini OCR (tuỳ chọn)
GEMINI_API_KEY=""
